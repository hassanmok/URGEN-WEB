# بعد ربط Supabase: نفّذ supabase/schema.sql في SQL Editor
# (جدول الفحوصات والفعاليات، buckets: event-images، partner-reports، وجداول partner_lab_users و partner_submissions)
#
# بوابة المختبرات الشريكة: المسار /partner على موقعك
# إنشاء حسابات المختبرات من لوحة /admin (تبويب طلبات المختبرات): انشر Edge Function من المجلد
#   supabase/functions/create-partner-lab-user
# في لوحة Supabase → Edge Functions (اسم الدالة: create-partner-lab-user).
# بدون الدالة يمكنك يدوياً: Authentication → Users ثم SQL:
#   insert into public.partner_lab_users (user_id, lab_display_name, partner_username)
#   values ('<uuid من auth.users>', 'اسم المختبر', 'اسم-المستخدم');
