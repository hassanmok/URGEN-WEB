# انسخ هذا الملف إلى `.env` واملأ القيم من لوحة تحكم Supabase: Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public site URL for sitemap.xml (defaults to https://www.urgenlab.com)
SITE_URL=https://www.urgenlab.com

# لوحة الإدارة (/admin) — للتطوير المحلي فقط بدون Supabase
# في الإنتاج: أنشئ مستخدم إدارة من Supabase → Authentication
# VITE_ADMIN_PASSWORD=

# بعد ربط Supabase: نفّذ supabase/schema.sql في SQL Editor
# (جدول الفحوصات والفعاليات والأخبار، buckets: event-images، news-images، partner-reports، وجداول partner_*)
#
# بوابة المختبرات الشريكة: المسار /partner على موقعك
# إنشاء حسابات المختبرات من لوحة /admin: انشر Edge Functions من
#   supabase/functions/create-partner-lab-user و manage-partner-lab-user
